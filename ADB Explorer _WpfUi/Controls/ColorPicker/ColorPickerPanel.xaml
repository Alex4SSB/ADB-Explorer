<UserControl
    x:Class="ADB_Explorer.Controls.ColorPicker.ColorPickerPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ADB_Explorer.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:strings="clr-namespace:ADB_Explorer.Strings"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="Root"
    IsTabStop="False"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!--  ═══ Spectrum (Hue × Saturation) ═══  -->
        <Canvas
            x:Name="SpectrumCanvas"
            Width="{Binding RelativeSource={RelativeSource Mode=Self}, Path=ActualHeight}"
            ClipToBounds="True"
            MouseDown="SpectrumCanvas_MouseDown"
            MouseMove="SpectrumCanvas_MouseMove"
            MouseUp="SpectrumCanvas_MouseUp">
            <!--  Rainbow: Hue 0→360 on X axis  -->
            <Rectangle
                Canvas.Left="0"
                Canvas.Top="0"
                Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Canvas}, Path=ActualHeight}"
                Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Canvas}, Path=ActualHeight}"
                RadiusX="4"
                RadiusY="4">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Offset="0.000" Color="#FFFF0000" />
                        <GradientStop Offset="0.167" Color="#FFFFFF00" />
                        <GradientStop Offset="0.333" Color="#FF00FF00" />
                        <GradientStop Offset="0.500" Color="#FF00FFFF" />
                        <GradientStop Offset="0.667" Color="#FF0000FF" />
                        <GradientStop Offset="0.833" Color="#FFFF00FF" />
                        <GradientStop Offset="1.000" Color="#FFFF0000" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <!--
                Saturation: opaque White (top, sat=1) → transparent (bottom, sat fades)
                Combined with rainbow: top row = full saturation, bottom = white
            -->
            <Rectangle
                Canvas.Left="0"
                Canvas.Top="0"
                Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Canvas}, Path=ActualHeight}"
                Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Canvas}, Path=ActualHeight}"
                RadiusX="4"
                RadiusY="4">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="Transparent" />
                        <GradientStop Offset="1" Color="White" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Border
                Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Canvas}, Path=ActualHeight}"
                Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Canvas}, Path=ActualHeight}"
                BorderBrush="{DynamicResource OpaqueBorderBrush}"
                BorderThickness="2"
                CornerRadius="4" />

            <!--  Spectrum thumb  -->
            <Ellipse
                x:Name="SpectrumThumb"
                Canvas.Left="-7"
                Canvas.Top="-7"
                Width="14"
                Height="14"
                Fill="Transparent"
                IsHitTestVisible="False"
                Stroke="White"
                StrokeThickness="2">
                <Ellipse.Effect>
                    <DropShadowEffect
                        BlurRadius="5"
                        Opacity="1"
                        ShadowDepth="0" />
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <!--  ═══ Color Preview ═══  -->
        <Border
            Grid.Column="2"
            Width="40"
            CornerRadius="4">
            <Border.Background>
                <SolidColorBrush x:Name="PreviewBrush" />
            </Border.Background>
            <Border
                BorderBrush="{DynamicResource OpaqueBorderBrush}"
                BorderThickness="2"
                CornerRadius="4" />
        </Border>

        <!--  ═══ Value Bar ═══  -->
        <Canvas
            x:Name="ValueCanvas"
            Grid.Column="4"
            Width="20"
            ClipToBounds="False"
            MouseDown="ValueCanvas_MouseDown"
            MouseMove="ValueCanvas_MouseMove"
            MouseUp="ValueCanvas_MouseUp">
            <Rectangle
                Canvas.Left="4"
                Canvas.Top="0"
                Width="12"
                Height="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Canvas}, Path=ActualHeight}"
                RadiusX="6"
                RadiusY="6"
                SnapsToDevicePixels="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop x:Name="ValueTopGradientStop" Offset="0" Color="Red" />
                        <GradientStop Offset="1" Color="Black" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <!--  Value thumb  -->
            <Ellipse
                x:Name="ValueThumb"
                Canvas.Left="1"
                Canvas.Top="-7"
                Width="18"
                Height="18"
                Fill="{DynamicResource TextFillColorPrimaryBrush}"
                IsHitTestVisible="False"
                SnapsToDevicePixels="False"
                Stroke="{DynamicResource ControlSolidFillColorDefaultBrush}"
                StrokeThickness="4" />
        </Canvas>

        <!--  ═══ Right-side controls ═══  -->
        <Grid Grid.Column="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="12" />
                <RowDefinition />
                <RowDefinition Height="12" />
                <RowDefinition />
                <RowDefinition Height="12" />
                <RowDefinition />
                <RowDefinition Height="12" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <!--  Hex  -->
            <ui:TextBox
                x:Name="HexTextBox"
                FlowDirection="LeftToRight"
                KeyDown="HexTextBox_KeyDown"
                LostFocus="HexTextBox_LostFocus" />

            <!--  Mode selector  -->
            <ComboBox
                x:Name="ModeComboBox"
                Grid.Row="2"
                FlowDirection="LeftToRight"
                SelectedIndex="0"
                SelectionChanged="ModeComboBox_SelectionChanged">
                <ComboBoxItem Content="RGB" />
                <ComboBoxItem Content="HSV" />
            </ComboBox>

            <!--  Channel 1  -->
            <ui:TextBox
                x:Name="Ch1Box"
                Grid.Row="4"
                FlowDirection="LeftToRight"
                KeyDown="ChannelBox_KeyDown"
                LostFocus="ChannelBox_LostFocus" />
            <TextBlock
                x:Name="Ch1Label"
                Grid.Row="4"
                Grid.Column="2"
                VerticalAlignment="Center"
                Text="{Binding Source={x:Static Member=strings:Resources.S_COLOR_RED}}" />

            <!--  Channel 2  -->
            <ui:TextBox
                x:Name="Ch2Box"
                Grid.Row="6"
                FlowDirection="LeftToRight"
                KeyDown="ChannelBox_KeyDown"
                LostFocus="ChannelBox_LostFocus" />
            <TextBlock
                x:Name="Ch2Label"
                Grid.Row="6"
                Grid.Column="2"
                VerticalAlignment="Center"
                Text="{Binding Source={x:Static Member=strings:Resources.S_COLOR_GREEN}}" />

            <!--  Channel 3  -->
            <ui:TextBox
                x:Name="Ch3Box"
                Grid.Row="8"
                FlowDirection="LeftToRight"
                KeyDown="ChannelBox_KeyDown"
                LostFocus="ChannelBox_LostFocus" />
            <TextBlock
                x:Name="Ch3Label"
                Grid.Row="8"
                Grid.Column="2"
                VerticalAlignment="Center"
                Text="{Binding Source={x:Static Member=strings:Resources.S_COLOR_BLUE}}" />

        </Grid>
    </Grid>
</UserControl>
