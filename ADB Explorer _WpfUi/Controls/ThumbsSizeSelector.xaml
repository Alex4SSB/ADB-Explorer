<UserControl
    x:Class="ADB_Explorer.Controls.ThumbsSizeSelector"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ADB_Explorer.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ADB_Explorer.Models"
    xmlns:strings="clr-namespace:ADB_Explorer.Strings"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="tsz"
    mc:Ignorable="d">
    <local:AdbMenu DataContext="{Binding ElementName=tsz}">
        <local:AdbMenu.Style>
            <Style BasedOn="{StaticResource AdbMenuStyle}" TargetType="local:AdbMenu">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Source={x:Static Member=models:Data.FileActions}, Path=IsAppDrive}" Value="True">
                        <Setter Property="IsEnabled" Value="False" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </local:AdbMenu.Style>
        <local:AdbMenuItem ItemsSource="{Binding Items}" ToolTip="{Binding Source={x:Static Member=strings:Resources.S_THUMBSIZE_TOOLTIP}}">
            <local:AdbMenuItem.Resources>
                <ui:FontIcon
                    x:Key="ThumbCheckedIcon"
                    Margin="14,0"
                    x:Shared="False"
                    FontSize="6"
                    Glyph="&#xF137;">
                    <ui:FontIcon.Style>
                        <Style BasedOn="{StaticResource GlyphFont}" TargetType="ui:FontIcon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked}" Value="False">
                                    <Setter Property="Visibility" Value="Hidden" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:FontIcon.Style>
                </ui:FontIcon>
            </local:AdbMenuItem.Resources>
            <local:AdbMenuItem.Header>
                <local:SimpleStackPanel Orientation="Horizontal" Spacing="6">
                    <ContentPresenter Content="{Binding SelectedIcon}" />
                    <TextBlock Margin="0,0,0,2" Text="{Binding Source={x:Static Member=strings:Resources.S_THUMBSIZE_TITLE}}" />
                    <ui:FontIcon
                        Margin="0,2,0,0"
                        FontSize="8"
                        Glyph="&#xE70D;" />
                </local:SimpleStackPanel>
            </local:AdbMenuItem.Header>
            <local:AdbMenuItem.ItemContainerStyle>
                <Style TargetType="local:AdbMenuItem">
                    <Setter Property="Icon" Value="{StaticResource ThumbCheckedIcon}" />
                    <Setter Property="Command" Value="{Binding Action.Command}" />
                </Style>
            </local:AdbMenuItem.ItemContainerStyle>
            <local:AdbMenuItem.ItemTemplate>
                <DataTemplate DataType="local:ThumbsSizeSelector.ThumbSizeItem">
                    <local:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                        <ContentPresenter Content="{Binding Icon}" />
                        <TextBlock Text="{Binding Name}" />
                    </local:SimpleStackPanel>
                </DataTemplate>
            </local:AdbMenuItem.ItemTemplate>
        </local:AdbMenuItem>
    </local:AdbMenu>
</UserControl>
