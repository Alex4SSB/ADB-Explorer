<UserControl
    x:Class="ADB_Explorer.Controls.DetailsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ADB_Explorer.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ADB_Explorer.Models"
    xmlns:strings="clr-namespace:ADB_Explorer.Strings"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="dc"
    mc:Ignorable="d">
    <local:AdbMenu DataContext="{Binding ElementName=dc}" Style="{StaticResource AdbMenuStyle}">
        <local:AdbMenuItem
            IsCheckable="True"
            IsChecked="{Binding IsChecked, Mode=TwoWay}"
            Style="{StaticResource WpfUiMenuItem}"
            ToolTip="{Binding Source={x:Static Member=strings:Resources.S_DETAILS_PANE_TOOLTIP}}">
            <local:AdbMenuItem.Header>
                <local:SimpleStackPanel Orientation="Horizontal" Spacing="6">
                    <ui:FontIcon RenderTransformOrigin="0.5,0.5">
                        <ui:FontIcon.Style>
                            <Style BasedOn="{StaticResource GlyphFont}" TargetType="ui:FontIcon">
                                <Setter Property="Glyph" Value="&#xE99C;" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Source={x:Static Member=models:Data.RuntimeSettings}, Path=IsRTL}" Value="False">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="-1" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Mode}" Value="Preview">
                                        <Setter Property="Glyph" Value="&#xE1AC;" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:FontIcon.Style>
                    </ui:FontIcon>
                    <TextBlock Margin="0,0,0,1">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding Source={x:Static Member=strings:Resources.S_THUMBSIZE_DETAILS}}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Mode}" Value="Preview">
                                        <Setter Property="Text" Value="{Binding Source={x:Static Member=strings:Resources.S_SIDE_PANE_PREVIEW}}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </local:SimpleStackPanel>
            </local:AdbMenuItem.Header>
        </local:AdbMenuItem>
    </local:AdbMenu>
</UserControl>
