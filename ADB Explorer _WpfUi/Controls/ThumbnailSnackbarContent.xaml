<UserControl
    x:Class="ADB_Explorer.Controls.ThumbnailSnackbarContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="root"
    mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>
    <StackPanel DataContext="{Binding ElementName=root}">
        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
        <StackPanel
            Margin="0,4,0,0"
            Orientation="Horizontal"
            Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVisibility}}">
            <ProgressBar
                Width="180"
                Height="6"
                Margin="0,0,6,0"
                VerticalAlignment="Center"
                Maximum="{Binding Maximum}"
                Minimum="0"
                Value="{Binding Value}">
                <ProgressBar.Style>
                    <Style BasedOn="{StaticResource FluentProgressBarStyle}" TargetType="ProgressBar">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Maximum}" Value="0">
                                <Setter Property="IsIndeterminate" Value="True" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
            <TextBlock VerticalAlignment="Center" Text="{Binding CounterText}" />
        </StackPanel>
    </StackPanel>
</UserControl>