<UserControl
    x:Class="ADB_Explorer.Controls.DetailsPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
    xmlns:local="clr-namespace:ADB_Explorer.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ADB_Explorer.Models"
    xmlns:strings="clr-namespace:ADB_Explorer.Strings"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:pdfImage="clr-namespace:PDFtoImage;assembly=PDFtoImage"
    x:Name="pane"
    d:DesignHeight="450"
    d:DesignWidth="300"
    d:Visibility="Visible"
    mc:Ignorable="d">
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Source={x:Static Member=models:Data.FileActions}, Path=IsExplorerVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOpen, RelativeSource={RelativeSource Mode=Self}}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>
    <Grid DataContext="{Binding ElementName=pane}">
        <Grid x:Name="ContentBox">
            <Grid>
                <local:AdbAvalonEditor x:Name="EditorTextBox" EditorText="{Binding EditorText, Mode=TwoWay}">
                    <local:AdbAvalonEditor.Style>
                        <Style TargetType="local:AdbAvalonEditor">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EditorText}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Source={x:Static Member=models:Data.Settings}, Path=SidePane}" Value="Details">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </local:AdbAvalonEditor.Style>
                </local:AdbAvalonEditor>
                <ScrollViewer x:Name="PdfScrollViewer" Visibility="Collapsed">
                    <ItemsControl x:Name="PdfPagesControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Image Source="{Binding Image}" />
                                    <Border
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Margin="6"
                                        Padding="4,2"
                                        Background="#99000000"
                                        CornerRadius="3">
                                        <TextBlock
                                            Text="{Binding Label}"
                                            Foreground="White"
                                            FontSize="11" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock
                    x:Name="NoPreviewTextBlock"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="12" />
            </Grid>
            <ScrollViewer>
                <ScrollViewer.Style>
                    <Style BasedOn="{StaticResource UiScrollViewer}" TargetType="ScrollViewer">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Source={x:Static Member=models:Data.Settings}, Path=SidePane}" Value="Preview">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="200" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Border>
                        <Image
                            x:Name="LargeFileIcon"
                            Margin="4,4,12,4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <Grid
                        Grid.Row="1"
                        Margin="0,0,0,0"
                        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                        <local:SimpleStackPanel Margin="20" Spacing="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Image x:Name="SmallFileIcon" Height="32">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Margin" Value="0,0,10,0" />
                                            <Style.Triggers>
                                                <Trigger Property="Source" Value="{x:Null}">
                                                    <Setter Property="Margin" Value="0" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <emoji:TextBlock
                                    x:Name="FileNameTextBlock"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    TextWrapping="Wrap" />
                            </Grid>
                            <Border
                                x:Name="InvalidSelectionBorder"
                                Padding="12"
                                BorderBrush="{DynamicResource SeparatorBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <ui:FontIcon
                                        FontSize="16"
                                        Foreground="{DynamicResource InfoBadgeInformationalSeverityBackgroundBrush}"
                                        Glyph="&#xF167;" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{Binding Source={x:Static Member=strings:Resources.S_DETAILS_MULTI_FILE_SELECTED}}"
                                        TextWrapping="Wrap" />
                                </Grid>
                            </Border>
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding File}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock
                                    Margin="0,0,0,10"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="{Binding Source={x:Static Member=strings:Resources.S_THUMBSIZE_DETAILS}}" />
                                <ItemsControl ItemsSource="{Binding ThumbnailInfoItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="20" />
                                                    <ColumnDefinition />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="{DynamicResource InfoBadgeInformationalSeverityBackgroundBrush}"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    Grid.Column="2"
                                                    HorizontalAlignment="Right"
                                                    FontSize="12"
                                                    Foreground="{DynamicResource InfoBadgeInformationalSeverityBackgroundBrush}"
                                                    Text="{Binding Value}"
                                                    TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style BasedOn="{StaticResource TooltipTextBlockStyle}" TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ValueIsLtr}" Value="True">
                                                                    <Setter Property="FlowDirection" Value="LeftToRight" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </local:SimpleStackPanel>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
            <Separator />
            <GridSplitter
                Width="8"
                VerticalAlignment="Stretch"
                Background="Transparent"
                Cursor="SizeWE"
                DragDelta="GridSplitter_DragDelta"
                FocusVisualStyle="{x:Null}" />
        </StackPanel>
    </Grid>
</UserControl>
