<UserControl
    x:Class="ADB_Explorer.Views.FileIconView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
    xmlns:local="clr-namespace:ADB_Explorer.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ADB_Explorer.Models"
    xmlns:viewmodels="clr-namespace:ADB_Explorer.ViewModels"
    d:DataContext="{d:DesignInstance Type=models:FileClass}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ToolTip x:Key="IconViewTooltip">
            <ToolTip.Style>
                <Style BasedOn="{StaticResource FluentTooltipStyle}" TargetType="ToolTip">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IconViewModel.IconViewTooltip}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ToolTip.Style>
            <TextBlock
                FlowDirection="LeftToRight"
                Text="{Binding IconViewModel.IconViewTooltip}"
                TextWrapping="Wrap" />
        </ToolTip>
    </UserControl.Resources>
    <Grid
        Width="140"
        Height="140"
        Margin="4"
        SnapsToDevicePixels="False">
        <Grid ToolTip="{StaticResource IconViewTooltip}">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid HorizontalAlignment="Center" FlowDirection="LeftToRight">
                <Image
                    MaxWidth="140"
                    MaxHeight="120"
                    HorizontalAlignment="Center"
                    d:Height="120"
                    d:Width="120"
                    Source="{Binding IconViewModel.LargeIcon}" />
                <Grid
                    MaxWidth="120"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom">
                    <Image
                        Width="32"
                        Height="32"
                        Margin="0,0,-13,-2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Source="{Binding IconViewModel.VideoIconOverlay}" />
                    <Image
                        Width="64"
                        Height="64"
                        Margin="0,0,0,14"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Source="{Binding IconViewModel.LargeIconOverlay}" />
                </Grid>
            </Grid>
            <emoji:TextBlock
                Grid.Row="1"
                MaxHeight="60"
                Margin="0,4,0,0"
                HorizontalAlignment="Center"
                FlowDirection="{Binding NameFlowDirection}"
                Style="{StaticResource DirectoryGridCellStyle}"
                Text="{Binding DisplayName}"
                TextAlignment="Center"
                TextWrapping="Wrap"
                ToolTip="{x:Null}" />
        </Grid>
    </Grid>
</UserControl>
