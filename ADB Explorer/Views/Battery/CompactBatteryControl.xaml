<UserControl
    x:Class="ADB_Explorer.Views.CompactBatteryControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ADB_Explorer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ADB_Explorer.Models"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DataContext="{d:DesignInstance Type=models:Battery}"
    mc:Ignorable="d">
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Source={x:Static models:Data.Settings}, Path=PollBattery}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ChargeState}" Value="Unknown">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>
    <controls:FluentPathIcon Margin="0,1,0,0" Data="{Binding BatteryIcon}">
        <controls:FluentPathIcon.Style>
            <Style BasedOn="{StaticResource DeviceHeaderPathIcon}" TargetType="controls:FluentPathIcon">
                <Setter Property="ToolTip">
                    <Setter.Value>
                        <ToolTip>
                            <TextBlock
                                NumberSubstitution.Substitution="NativeNational"
                                Style="{StaticResource TextBlockStyle}"
                                Text="{Binding CompactStateString}" />
                        </ToolTip>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding FullyCharged}" Value="True">
                        <Setter Property="Foreground" Value="#FF107C0F" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding BatteryLow}" Value="True">
                        <Setter Property="Foreground" Value="#FFF44336" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ChargeState}" Value="Charging">
                        <Setter Property="Margin" Value="0,-5,0,0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </controls:FluentPathIcon.Style>
    </controls:FluentPathIcon>
</UserControl>
