<UserControl
    x:Class="ADB_Explorer.Views.DetailedBatteryControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ADB_Explorer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ADB_Explorer.Models"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DataContext="{d:DesignInstance Type=models:Battery}"
    mc:Ignorable="d">
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Source={x:Static models:Data.Settings}, Path=PollBattery}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ChargeState}" Value="Unknown">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>
    <controls:SimpleStackPanel
        VerticalAlignment="Center"
        Orientation="Horizontal"
        Spacing="6"
        ToolTipService.InitialShowDelay="0"
        ToolTipService.Placement="Top"
        ToolTipService.ShowDuration="60000">
        <controls:SimpleStackPanel.ToolTip>
            <controls:SimpleStackPanel Spacing="4">
                <controls:SimpleStackPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </controls:SimpleStackPanel.Resources>
                <TextBlock Text="{Binding BatteryStateString}" />
                <TextBlock Text="{Binding BatteryHealthString}" />
                <TextBlock Text="{Binding VoltageString}" />
                <TextBlock Text="{Binding CurrentConsumption}" />
                <TextBlock Text="{Binding TemperatureString}" />
            </controls:SimpleStackPanel>
        </controls:SimpleStackPanel.ToolTip>
        <StackPanel FlowDirection="LeftToRight" Orientation="Horizontal">
            <TextBlock Text="{Binding Level}" />
            <TextBlock Text="%" />
        </StackPanel>
        <controls:FluentPathIcon
            Width="24"
            VerticalAlignment="Center"
            Data="{Binding BatteryIcon}"
            Stretch="Uniform">
            <controls:FluentPathIcon.Style>
                <Style BasedOn="{StaticResource DeviceHeaderPathIcon}" TargetType="controls:FluentPathIcon">
                    <Style.Triggers>
                        <Trigger Property="DataContext" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <DataTrigger Binding="{Binding Source={x:Static models:Data.Settings}, Path=PollBattery}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ChargeState}" Value="Unknown">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding FullyCharged}" Value="True">
                            <Setter Property="Foreground" Value="#FF107C0F" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding BatteryLow}" Value="True">
                            <Setter Property="Foreground" Value="#FFF44336" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ChargeState}" Value="Charging">
                            <Setter Property="Margin" Value="0,-5,0,0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:FluentPathIcon.Style>
        </controls:FluentPathIcon>
    </controls:SimpleStackPanel>
</UserControl>
