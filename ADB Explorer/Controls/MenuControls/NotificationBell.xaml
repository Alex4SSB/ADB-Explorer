<UserControl
    x:Class="ADB_Explorer.Controls.NotificationBell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ADB_Explorer.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:strings="clr-namespace:ADB_Explorer.Strings"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="Bell"
    FontFamily="Segoe UI"
    mc:Ignorable="d">
    <local:AdbMenu DataContext="{Binding ElementName=Bell}" Style="{StaticResource AdbMenuStyle}">
        <local:AdbMenuItem ItemsSource="{Binding Notifications}" ToolTip="{Binding Source={x:Static Member=strings:Resources.S_NOTIFICATIONS_TITLE}}">
            <local:AdbMenuItem.Style>
                <Style BasedOn="{StaticResource AdbMenuItemStyle}" TargetType="local:AdbMenuItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Notifications.Count}" Value="0">
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </local:AdbMenuItem.Style>
            <local:AdbMenuItem.ItemContainerStyle>
                <Style TargetType="local:AdbMenuItem">
                    <Setter Property="Header" Value="{Binding Title}" />
                    <Setter Property="ToolTip" Value="{Binding Tooltip}" />
                    <Setter Property="Command" Value="{Binding Command}" />
                </Style>
            </local:AdbMenuItem.ItemContainerStyle>
            <local:AdbMenuItem.Header>
                <Grid Margin="0,-6,-4,0">
                    <ui:FontIcon
                        Margin="0,4,4,0"
                        FontSize="24"
                        Glyph="&#xF2A3;" />
                    <Border
                        Width="16"
                        Height="15"
                        Margin="8,0,0,4"
                        Background="{DynamicResource SystemFillColorCautionBrush}"
                        BorderBrush="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                        BorderThickness="2"
                        CornerRadius="30">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Notifications.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock
                            Margin="0,0,0,1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                            Text="{Binding Notifications.Count}" />
                    </Border>
                </Grid>
            </local:AdbMenuItem.Header>
        </local:AdbMenuItem>
    </local:AdbMenu>
</UserControl>
