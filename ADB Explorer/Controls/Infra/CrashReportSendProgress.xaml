<UserControl
    x:Class="ADB_Explorer.Controls.CrashReportSendProgress"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ADB_Explorer.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    d:DesignWidth="420"
    IsTabStop="False"
    mc:Ignorable="d">
    <local:SimpleStackPanel DataContext="{Binding ElementName=Root}" Spacing="12">
        <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />
        <ProgressBar
            Height="4"
            IsIndeterminate="True"
            Style="{StaticResource FluentProgressBarStyle}"
            Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
    </local:SimpleStackPanel>
</UserControl>
