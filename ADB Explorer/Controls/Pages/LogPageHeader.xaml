<UserControl
    x:Class="ADB_Explorer.Controls.Pages.LogPageHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ADB_Explorer.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:ADB_Explorer.ViewModels.Pages"
    xmlns:strings="clr-namespace:ADB_Explorer.Strings"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DataContext="{d:DesignInstance Type=pages:LogViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    FlowDirection="LeftToRight"
    mc:Ignorable="d">
    <Grid>
        <ui:RichTextBox x:Name="LogTextBox" FontFamily="Consolas" />
        <Border
            Margin="20,6"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="#407F7F7F"
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="4">
            <local:AdbMenu
                x:Name="LogControlsPanel"
                Margin="-4"
                Style="{StaticResource LogControlsPanelStyle}" />
        </Border>
    </Grid>
</UserControl>
