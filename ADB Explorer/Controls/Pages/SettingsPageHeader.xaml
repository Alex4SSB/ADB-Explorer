<UserControl
    x:Class="ADB_Explorer.Controls.Pages.SettingsPageHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ADB_Explorer.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:ADB_Explorer.Helpers"
    xmlns:local="clr-namespace:ADB_Explorer.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ADB_Explorer.Models"
    xmlns:pages="clr-namespace:ADB_Explorer.ViewModels.Pages"
    xmlns:resources="clr-namespace:ADB_Explorer.Resources"
    xmlns:services="clr-namespace:ADB_Explorer.Services"
    xmlns:strings="clr-namespace:ADB_Explorer.Strings"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DataContext="{d:DesignInstance Type=pages:SettingsViewModel}"
    d:DesignHeight="50"
    d:DesignWidth="600"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:ControlAppearanceToCardBrushConverter x:Key="ControlAppearanceToCardBrushConverter" />
        <Style x:Key="CollapsedTextBlock" TargetType="TextBlock">
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RightHorizontalItemsControlStyle" TargetType="ItemsControl">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <WrapPanel FlowDirection="RightToLeft" />
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Source={x:Static Member=models:Data.FileOpQ}, Path=IsActive}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style
            x:Key="LinkTooltipStyle"
            BasedOn="{StaticResource FluentTooltipStyle}"
            TargetType="ToolTip">
            <Setter Property="FlowDirection" Value="LeftToRight" />
        </Style>
        <Style x:Key="SettingsIconPresenterStyle" TargetType="ContentPresenter">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IconContent}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="SettingsActionTemplate" DataType="services:SettingsAction">
            <ui:Button
                Appearance="Primary"
                Command="{Binding Command}"
                Style="{StaticResource RestartAppButtonStyle}"
                ToolTip="{Binding Tooltip}">
                <ui:FontIcon Glyph="{Binding Icon}" />
            </ui:Button>
        </DataTemplate>
        <Grid
            x:Key="SettingsCardHeader"
            MinHeight="37"
            x:Shared="False">
            <TextBlock
                VerticalAlignment="Center"
                Text="{Binding Description}"
                TextWrapping="Wrap" />
        </Grid>
        <Style
            x:Key="SettingsCardHeaderStyle"
            BasedOn="{StaticResource DefaultUiCardControlStyle}"
            TargetType="ui:CardControl">
            <Setter Property="MinHeight" Value="70" />
            <Setter Property="Icon" Value="{Binding IconContent}" />
            <Setter Property="Header" Value="{StaticResource SettingsCardHeader}" />
            <Setter Property="Background">
                <Setter.Value>
                    <Binding Converter="{StaticResource ControlAppearanceToCardBrushConverter}" Path="CardAppearance" />
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <Binding
                        Converter="{StaticResource ControlAppearanceToCardBrushConverter}"
                        ConverterParameter="Border"
                        Path="CardAppearance" />
                </Setter.Value>
            </Setter>
            <Setter Property="ToolTip">
                <Setter.Value>
                    <ToolTip MaxWidth="600" Style="{StaticResource FluentTooltipStyle}">
                        <TextBlock Text="{Binding Info}" TextWrapping="Wrap" />
                    </ToolTip>
                </Setter.Value>
            </Setter>
            <Setter Property="ToolTipService.InitialShowDelay" Value="0" />
            <Setter Property="ToolTipService.ShowDuration" Value="60000" />
            <Setter Property="ToolTipService.Placement" Value="Bottom" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CardAppearance}" Value="{x:Null}">
                    <Setter Property="Background" Value="{DynamicResource CardBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Info}" Value="{x:Null}">
                    <Setter Property="ToolTip" Value="{x:Null}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style
            x:Key="SettingsCardExpanderStyle"
            BasedOn="{StaticResource DefaultUiCardExpanderStyle}"
            TargetType="ui:CardExpander">
            <Setter Property="Icon" Value="{Binding IconContent}" />
            <Setter Property="Header" Value="{StaticResource SettingsCardHeader}" />
        </Style>
        <Style
            x:Key="SettingsCardActionStyle"
            BasedOn="{StaticResource DefaultUiCardActionStyle}"
            TargetType="ui:CardAction">
            <Setter Property="MinHeight" Value="70" />
            <Setter Property="IsChevronVisible" Value="False" />
            <Setter Property="Command" Value="{Binding Command.Command}" />
            <Setter Property="ToolTip">
                <Setter.Value>
                    <ToolTip Content="{Binding ToolTip}" Style="{StaticResource LinkTooltipStyle}" />
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="InfoSettingTemplate" DataType="services:InfoSetting">
            <ui:CardControl Style="{StaticResource SettingsCardHeaderStyle}">
                <ui:CardControl.Header>
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HeaderAlignment}" Value="Center">
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="{Binding FontFamily}"
                            FontSize="{Binding FontSize}"
                            Text="{Binding Description}"
                            TextAlignment="{Binding HeaderAlignment}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Grid.Row="1"
                            Style="{StaticResource CollapsedTextBlock}"
                            Text="{Binding AltText}"
                            TextAlignment="{Binding HeaderAlignment}" />
                    </Grid>
                </ui:CardControl.Header>
            </ui:CardControl>
        </DataTemplate>
        <DataTemplate x:Key="LinkSettingTemplate" DataType="services:LinkSetting">
            <ui:CardAction Style="{StaticResource SettingsCardActionStyle}">
                <ui:CardAction.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ContentPresenter
                            Grid.RowSpan="2"
                            Margin="0,0,10,0"
                            Content="{Binding IconContent}"
                            FlowDirection="LeftToRight" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Text="{Binding Description}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource CollapsedTextBlock}"
                            Text="{Binding AltText}" />
                        <ui:FontIcon
                            Grid.Column="2"
                            HorizontalAlignment="Right"
                            Glyph="&#xE8A7;">
                            <ui:FontIcon.Style>
                                <Style BasedOn="{StaticResource GlyphFont}" TargetType="ui:FontIcon">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Source={x:Static Member=models:Data.RuntimeSettings}, Path=IsRTL}" Value="True">
                                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="-1" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:FontIcon.Style>
                        </ui:FontIcon>
                    </Grid>
                </ui:CardAction.Content>
            </ui:CardAction>
        </DataTemplate>
        <DataTemplate x:Key="MultiLinkSettingTemplate" DataType="services:MultiLinkSetting">
            <ui:CardExpander Style="{StaticResource SettingsCardExpanderStyle}">
                <ItemsControl FlowDirection="LeftToRight" ItemsSource="{Binding Links}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:HyperlinkButton Content="{Binding Description}" NavigateUri="{Binding Url}">
                                <ui:HyperlinkButton.Style>
                                    <Style BasedOn="{StaticResource DefaultUiHyperlinkButtonStyle}" TargetType="ui:HyperlinkButton">
                                        <Setter Property="ToolTip">
                                            <Setter.Value>
                                                <ToolTip Content="{Binding Url}" Style="{StaticResource LinkTooltipStyle}" />
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ui:HyperlinkButton.Style>
                            </ui:HyperlinkButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ui:CardExpander>
        </DataTemplate>
        <DataTemplate x:Key="LongDescriptionSettingTemplate" DataType="services:LongDescriptionSetting">
            <ui:CardExpander Style="{StaticResource SettingsCardExpanderStyle}">
                <TextBlock Text="{Binding AltText}" TextWrapping="Wrap" />
            </ui:CardExpander>
        </DataTemplate>
        <DataTemplate x:Key="BoolSettingTemplate" DataType="services:BoolSetting">
            <ui:CardControl Style="{StaticResource SettingsCardHeaderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <ItemsControl
                        Margin="0,0,0,4"
                        ItemTemplate="{StaticResource SettingsActionTemplate}"
                        ItemsSource="{Binding Commands}"
                        Style="{StaticResource RightHorizontalItemsControlStyle}" />
                    <local:SimpleStackPanel
                        Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="10">
                        <TextBlock Text="{Binding Label}" />
                        <ui:ToggleSwitch IsChecked="{Binding Value, Mode=TwoWay}" />
                    </local:SimpleStackPanel>
                </Grid>
            </ui:CardControl>
        </DataTemplate>
        <DataTemplate x:Key="CultureInfoSettingTemplate" DataType="services:ComboSetting">
            <ui:CardControl Style="{StaticResource SettingsCardHeaderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <ItemsControl
                        Margin="0,0,0,4"
                        ItemTemplate="{StaticResource SettingsActionTemplate}"
                        ItemsSource="{Binding Commands}"
                        Style="{StaticResource RightHorizontalItemsControlStyle}" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Margin="6,0"
                            VerticalAlignment="Center"
                            Text="{Binding AltLabel}" />
                        <ComboBox
                            Grid.Column="1"
                            VerticalContentAlignment="Center"
                            ContextMenu="{x:Null}"
                            ItemsSource="{Binding Options}"
                            MaxDropDownHeight="287"
                            SelectedValue="{Binding Value, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ThreeLetterISOLanguageName}" Value="ivl">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock HorizontalAlignment="Left" Text="{Binding NativeName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FlowDirection" Value="LeftToRight" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TextInfo.IsRightToLeft}" Value="True">
                                                                <Setter Property="FlowDirection" Value="RightToLeft" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock
                                                Grid.Column="1"
                                                Margin="16,2,0,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource ConsoleFont}"
                                                FontSize="12"
                                                Text="{Binding Name}" />
                                        </Grid>
                                        <TextBlock Text="{x:Static strings:Resources.S_SETTINGS_THEME_DEFAULT}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ThreeLetterISOLanguageName}" Value="ivl">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                </Grid>
            </ui:CardControl>
        </DataTemplate>
        <DataTemplate x:Key="GroupedEnumSettingTemplate" DataType="services:SimpleComboSetting`1">
            <ui:CardControl Style="{StaticResource SettingsCardHeaderStyle}">
                <ComboBox
                    ContextMenu="{x:Null}"
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding Options}"
                    SelectedValue="{Binding Value, Mode=TwoWay}"
                    SelectedValuePath="Key">
                    <ComboBox.ItemContainerStyle>
                        <Style BasedOn="{StaticResource DefaultComboBoxItemStyle}" TargetType="ComboBoxItem">
                            <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
            </ui:CardControl>
        </DataTemplate>
        <DataTemplate x:Key="TextboxSettingTemplate" DataType="services:StringSetting">
            <ui:CardControl Style="{StaticResource SettingsCardHeaderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <ItemsControl
                        Margin="0,0,0,4"
                        ItemTemplate="{StaticResource SettingsActionTemplate}"
                        ItemsSource="{Binding Commands}"
                        Style="{StaticResource RightHorizontalItemsControlStyle}" />
                    <ui:TextBox
                        Grid.Row="1"
                        Width="250"
                        IsReadOnly="True"
                        PlaceholderText="{x:Static strings:Resources.S_PLACEHOLDER_NOT_SET}"
                        Text="{Binding Value}">
                        <ui:TextBox.Style>
                            <Style BasedOn="{StaticResource AdbTextBoxStyle}" TargetType="ui:TextBox">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="FlowDirection" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Grid}, Path=FlowDirection}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ui:TextBox.Style>
                    </ui:TextBox>
                </Grid>
            </ui:CardControl>
        </DataTemplate>
        <DataTemplate x:Key="NumericSettingTemplate" DataType="services:NumericSetting">
            <ui:CardControl Style="{StaticResource SettingsCardHeaderStyle}">
                <local:SimpleStackPanel
                    FlowDirection="LeftToRight"
                    Orientation="Horizontal"
                    Spacing="6">
                    <ui:NumberBox
                        ClearButtonEnabled="False"
                        ContextMenu="{x:Null}"
                        Maximum="{Binding MaxValue}"
                        Minimum="{Binding MinValue}"
                        SmallChange="1"
                        Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock VerticalAlignment="Center" Text="{Binding Unit}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </local:SimpleStackPanel>
            </ui:CardControl>
        </DataTemplate>

        <DataTemplate x:Key="ColorSettingTemplate" DataType="services:ColorSetting">
            <ui:CardControl Style="{StaticResource SettingsCardHeaderStyle}">
                <ui:Button HorizontalAlignment="Right" Command="{Binding PickColorCommand}">
                    <local:SimpleStackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{Binding Source={x:Static Member=strings:Resources.S_MENU_EDIT}}" />
                        <Border Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ui:Button}, Path=ActualHeight}" CornerRadius="4">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding PickerColor}" />
                            </Border.Background>
                        </Border>
                    </local:SimpleStackPanel>
                </ui:Button>
            </ui:CardControl>
        </DataTemplate>

        <helpers:SettingsTemplateSelector
            x:Key="GroupedSettingsTemplateSelector"
            BoolSettingTemplate="{StaticResource BoolSettingTemplate}"
            ColorSettingTemplate="{StaticResource ColorSettingTemplate}"
            CultureInfoSettingTemplate="{StaticResource CultureInfoSettingTemplate}"
            EnumSettingTemplate="{StaticResource GroupedEnumSettingTemplate}"
            InfoSettingTemplate="{StaticResource InfoSettingTemplate}"
            LinkSettingTemplate="{StaticResource LinkSettingTemplate}"
            LongDescriptionTemplate="{StaticResource LongDescriptionSettingTemplate}"
            MultiLinkSettingTemplate="{StaticResource MultiLinkSettingTemplate}"
            NumericTemplate="{StaticResource NumericSettingTemplate}"
            TextboxSettingTemplate="{StaticResource TextboxSettingTemplate}" />
        <Style
            x:Key="SettingsContainerStyle"
            BasedOn="{StaticResource StretchListViewItem}"
            TargetType="ui:ListViewItem">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Visibility" Value="{Binding Visibility}" />
        </Style>
    </UserControl.Resources>
    <Grid Margin="42,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition
                Width="4*"
                MinWidth="400"
                MaxWidth="1000" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border
                Margin="0,0,0,8"
                BorderBrush="Gray"
                BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:Button
                        Margin="4,0,8,0"
                        Padding="11,5,11,5"
                        Command="{Binding SortSettingsCommand}">
                        <ui:Button.Style>
                            <Style BasedOn="{StaticResource DefaultUiButtonStyle}" TargetType="ui:Button">
                                <Setter Property="ToolTip" Value="{Binding Source={x:Static Member=strings:Resources.S_SEARCH_VIEW}}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SortedView}" Value="True">
                                        <Setter Property="ToolTip" Value="{Binding Source={x:Static Member=strings:Resources.S_EXIT_SEARCH}}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                        <ui:FontIcon FontSize="20">
                            <ui:FontIcon.Style>
                                <Style BasedOn="{StaticResource GlyphFont}" TargetType="ui:FontIcon">
                                    <Setter Property="Glyph" Value="&#xE721;" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SortedView}" Value="True">
                                            <Setter Property="Glyph" Value="&#xE711;" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:FontIcon.Style>
                        </ui:FontIcon>
                    </ui:Button>
                    <TextBlock
                        Grid.Column="1"
                        Margin="0,0,0,4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Text="{Binding Source={x:Static Member=strings:Resources.S_SETTINGS_TITLE}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SortedView}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Grid Grid.Column="1">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SortedView}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <ui:TextBox
                            x:Name="SettingsSearchBox"
                            Height="32"
                            Padding="30,5,30,6"
                            PlaceholderText="{x:Static strings:Resources.S_SEARCH_SETTINGS}"
                            Style="{StaticResource AdbTextBoxStyle}"
                            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <ui:FontIcon
                            Margin="6,0,0,0"
                            HorizontalAlignment="Left"
                            Glyph="&#xE721;"
                            IsHitTestVisible="False"
                            Opacity="0.7" />
                    </Grid>
                    <ui:Button
                        Grid.Column="2"
                        Margin="8,4,4,4"
                        Padding="8,4"
                        Appearance="Danger"
                        Command="{Binding ResetSettingsCommand}"
                        ToolTip="{Binding Source={x:Static Member=strings:Resources.S_RESET_SETTINGS_TITLE}}">
                        <Path
                            Width="24"
