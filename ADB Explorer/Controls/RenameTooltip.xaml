<UserControl
    x:Class="ADB_Explorer.Controls.RenameTooltip"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ADB_Explorer.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ADB_Explorer.Models"
    xmlns:strings="clr-namespace:ADB_Explorer.Strings"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    TextElement.FontSize="14"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="RenameStatusIcon"
            BasedOn="{StaticResource GlyphFont}"
            TargetType="ui:FontIcon">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Glyph" Value="&#xF13D;" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Foreground" Value="{DynamicResource TrashDriveAltBorder}" />
        </Style>
    </UserControl.Resources>
    <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">
        <Border
            x:Name="TooltipBorder"
            Padding="12"
            d:Visibility="Visible"
            Background="{DynamicResource FlyoutBackground}"
            BorderBrush="{DynamicResource FlyoutBorderBrush}"
            BorderThickness="1"
            CornerRadius="4"
            SnapsToDevicePixels="True">
            <Border.RenderTransform>
                <TranslateTransform x:Name="TooltipTranslate" />
            </Border.RenderTransform>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Source={x:Static Member=models:Data.FileActions}, Path=IsExplorerEditing}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="4" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <ui:FontIcon>
                    <ui:FontIcon.Style>
                        <Style BasedOn="{StaticResource RenameStatusIcon}" TargetType="ui:FontIcon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenameUnixLegal}" Value="True">
                                    <Setter Property="Glyph" Value="&#xF13E;" />
                                    <Setter Property="Foreground" Value="{DynamicResource NewDeviceAltBorder}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:FontIcon.Style>
                </ui:FontIcon>
                <ui:FontIcon Grid.Row="1">
                    <ui:FontIcon.Style>
                        <Style BasedOn="{StaticResource RenameStatusIcon}" TargetType="ui:FontIcon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenameNamingLegal}" Value="True">
                                    <Setter Property="Glyph" Value="&#xF13E;" />
                                    <Setter Property="Foreground" Value="{DynamicResource NewDeviceAltBorder}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:FontIcon.Style>
                </ui:FontIcon>
                <ui:FontIcon Grid.Row="2">
                    <ui:FontIcon.Style>
                        <Style BasedOn="{StaticResource RenameStatusIcon}" TargetType="ui:FontIcon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenameWindowsLegal}" Value="True">
                                    <Setter Property="Glyph" Value="&#xF13E;" />
                                    <Setter Property="Foreground" Value="{DynamicResource NewDeviceAltBorder}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:FontIcon.Style>
                </ui:FontIcon>
                <ui:FontIcon Grid.Row="3">
                    <ui:FontIcon.Style>
                        <Style BasedOn="{StaticResource RenameStatusIcon}" TargetType="ui:FontIcon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenameDriveRootLegal}" Value="True">
                                    <Setter Property="Glyph" Value="&#xF13E;" />
                                    <Setter Property="Foreground" Value="{DynamicResource NewDeviceAltBorder}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:FontIcon.Style>
                </ui:FontIcon>
                <ui:FontIcon Grid.Row="4">
                    <ui:FontIcon.Style>
                        <Style BasedOn="{StaticResource RenameStatusIcon}" TargetType="ui:FontIcon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenameUnique}" Value="True">
                                    <Setter Property="Glyph" Value="&#xF13E;" />
                                    <Setter Property="Foreground" Value="{DynamicResource NewDeviceAltBorder}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:FontIcon.Style>
                </ui:FontIcon>
                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Text="{Binding Source={x:Static Member=strings:Resources.S_POPUP_UNIX_NAMING}}" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Text="{Binding Source={x:Static Member=strings:Resources.S_POPUP_RESTRICTED_NAMING}}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Text="{Binding Source={x:Static Member=strings:Resources.S_POPUP_WINDOWS_NAMING}}" />
                <TextBlock
                    Grid.Row="3"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Text="{Binding Source={x:Static Member=strings:Resources.S_POPUP_DRIVE_ROOT_NAMING}}" />
                <TextBlock
                    Grid.Row="4"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Text="{Binding Source={x:Static Member=strings:Resources.S_POPUP_UNIQUE_NAME}}" />
            </Grid>
        </Border>
    </Canvas>
</UserControl>
