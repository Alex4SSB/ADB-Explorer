<UserControl
    x:Class="ADB_Explorer.Controls.DetailsAndPreviewIcon"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ADB_Explorer.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ADB_Explorer.Models"
    x:Name="root"
    mc:Ignorable="d">
    <Grid DataContext="{Binding ElementName=root}" RenderTransformOrigin="0.5,0.5">
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Source={x:Static Member=models:Data.RuntimeSettings}, Path=IsRTL}" Value="False">
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="-1" />
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Path
            Width="{Binding Size}"
            Height="{Binding Size}"
            d:Fill="White"
            Data="M4.75 8.5C4.75 8.08579 5.08579 7.75 5.5 7.75H6.75C7.16421 7.75 7.5 8.08579 7.5 8.5C7.5 8.91421 7.16421 9.25 6.75 9.25H5.5C5.08579 9.25 4.75 8.91421 4.75 8.5ZM4.75 12C4.75 11.5858 5.08579 11.25 5.5 11.25H6.75C7.16421 11.25 7.5 11.5858 7.5 12C7.5 12.4142 7.16421 12.75 6.75 12.75H5.5C5.08579 12.75 4.75 12.4142 4.75 12ZM4.75 15.5C4.75 15.0858 5.08579 14.75 5.5 14.75H6.75C7.16421 14.75 7.5 15.0858 7.5 15.5C7.5 15.9142 7.16421 16.25 6.75 16.25H5.5C5.08579 16.25 4.75 15.9142 4.75 15.5ZM5.25 4C3.45507 4 2 5.45507 2 7.25V16.75C2 18.5449 3.45508 20 5.25 20H18.75C20.5449 20 22 18.5449 22 16.75V7.25C22 5.45507 20.5449 4 18.75 4H5.25ZM18.75 18.5H10V5.5H18.75C19.7165 5.5 20.5 6.2835 20.5 7.25V16.75C20.5 17.7165 19.7165 18.5 18.75 18.5ZM5.25 5.5H8.5V18.5H5.25C4.2835 18.5 3.5 17.7165 3.5 16.75V7.25C3.5 6.2835 4.2835 5.5 5.25 5.5Z"
            Fill="{DynamicResource TextFillColorPrimaryBrush}"
            Stretch="{Binding Stretch}">
            <Path.Style>
                <Style TargetType="Path">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Mode}" Value="Preview">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Path.Style>
        </Path>
        <Path
            Width="{Binding Size}"
            Height="{Binding Size}"
            d:Fill="White"
            d:Margin="0,20,0,0"
            Data="M2 7.25C2 5.45507 3.45507 4 5.25 4H18.75C20.5449 4 22 5.45507 22 7.25V16.75C22 18.5449 20.5449 20 18.75 20H5.25C3.45508 20 2 18.5449 2 16.75V7.25ZM9.5 5.5V18.5H18.75C19.7165 18.5 20.5 17.7165 20.5 16.75V7.25C20.5 6.2835 19.7165 5.5 18.75 5.5H9.5ZM8 5.5H5.25C4.2835 5.5 3.5 6.2835 3.5 7.25V16.75C3.5 17.7165 4.2835 18.5 5.25 18.5H8V5.5Z"
            Fill="{DynamicResource TextFillColorPrimaryBrush}"
            Stretch="{Binding Stretch}">
            <Path.Style>
                <Style TargetType="Path">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Mode}" Value="Details">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Path.Style>
        </Path>
    </Grid>
</UserControl>
