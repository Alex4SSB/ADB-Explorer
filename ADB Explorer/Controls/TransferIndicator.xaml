<UserControl
    x:Class="ADB_Explorer.Controls.TransferIndicator"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:ADB_Explorer.Helpers"
    xmlns:local="clr-namespace:ADB_Explorer.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ADB_Explorer.Models"
    xmlns:strings="clr-namespace:ADB_Explorer.Strings"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:windows="clr-namespace:ADB_Explorer.ViewModels.Windows"
    x:Name="transferIndicator"
    d:DataContext="{d:DesignInstance Type=windows:MainWindowViewModel}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="TransferIndicatorIconStyle"
            BasedOn="{StaticResource GlyphFont}"
            TargetType="ui:FontIcon">
            <Setter Property="FontSize" Value="10" />
        </Style>
        <ToolTip x:Key="TransferIndicatorToolTip">
            <Grid>
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ServerUnresponsive}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{Binding Source={x:Static Member=strings:Resources.S_ADB_DISK_USAGE}}" />
                    <TextBlock>
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource StringFormatConverter}" ConverterParameter="{x:Static strings:Resources.S_DISK_USAGE_READ}">
                                <Binding Path="AdbReadRate" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock>
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource StringFormatConverter}" ConverterParameter="{x:Static strings:Resources.S_DISK_USAGE_WRITE}">
                                <Binding Path="AdbWriteRate" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ServerUnresponsive}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontWeight="Bold"
                        Text="{Binding Source={x:Static Member=strings:Resources.S_SERVER_UNRESPONSIVE}}" />
                    <Separator Margin="-6,4" />
                    <TextBlock Text="{Binding LastResponse}" />
                    <TextBlock
                        Margin="0,2,0,0"
                        HorizontalAlignment="Center"
                        Text="{Binding Source={x:Static Member=strings:Resources.S_TOOLTIP_MORE_INFO}}" />
                </StackPanel>
            </Grid>
        </ToolTip>
    </UserControl.Resources>
    <UserControl.Style>
        <Style TargetType="local:TransferIndicator">
            <Setter Property="IsUpVisible" Value="{Binding IsAdbReadActive}" />
            <Setter Property="IsDownVisible" Value="{Binding IsAdbWriteActive}" />
            <Setter Property="ServerUnresponsive" Value="{Binding ServerUnresponsive}" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Source={x:Static Member=helpers:AdbHelper.CurrentAdbState}, Path=Status}" Value="Valid">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>
    <local:AdbMenu d:Background="#202020" Style="{StaticResource AdbMenuStyle}">
        <local:AdbMenuItem
            x:Name="RootMenuItem"
            Style="{StaticResource AdbMenuItemStyle}"
            ToolTip="{StaticResource TransferIndicatorToolTip}"
            ToolTipService.InitialShowDelay="0"
            ToolTipService.Placement="Bottom"
            ToolTipService.ShowDuration="60000">
            <local:AdbMenuItem.Header>
                <Grid Margin="-4" FlowDirection="LeftToRight">
                    <ui:FontIcon
                        Margin="0,0,0,0"
                        d:Foreground="White"
                        FontSize="24"
                        Glyph="&#xE965;" />
                    <Grid Margin="0,-10,-10,0" d:Visibility="Hidden">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ServerUnresponsive, ElementName=transferIndicator}" Value="False">
                                        <Setter Property="Visibility" Value="Hidden" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <ui:FontIcon
                            d:Foreground="#202020"
                            FontSize="16"
                            Foreground="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                            Glyph="&#xF136;" />
                        <ui:FontIcon
                            Margin="0,1.5,0,0"
                            d:Foreground="#FF99A4"
                            FontSize="14"
                            Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                            Glyph="&#xEB90;" />
                    </Grid>
                    <Grid Margin="-27,0,0,0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ServerUnresponsive, ElementName=transferIndicator}" Value="True">
                                        <Setter Property="Visibility" Value="Hidden" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <ui:FontIcon Glyph="&#xEDD7;">
                            <ui:FontIcon.Style>
                                <Style BasedOn="{StaticResource TransferIndicatorIconStyle}" TargetType="ui:FontIcon">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUpVisible, ElementName=transferIndicator}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:FontIcon.Style>
                        </ui:FontIcon>
                        <ui:FontIcon
                            d:Foreground="#4CC2FF"
                            Foreground="{DynamicResource AccentButtonBackground}"
                            Glyph="&#xEDDB;">
                            <ui:FontIcon.Style>
                                <Style BasedOn="{StaticResource TransferIndicatorIconStyle}" TargetType="ui:FontIcon">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUpVisible, ElementName=transferIndicator}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:FontIcon.Style>
                        </ui:FontIcon>
                    </Grid>
                    <Grid Margin="26,0,0,0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ServerUnresponsive, ElementName=transferIndicator}" Value="True">
                                        <Setter Property="Visibility" Value="Hidden" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <ui:FontIcon Glyph="&#xEDD8;">
                            <ui:FontIcon.Style>
                                <Style BasedOn="{StaticResource TransferIndicatorIconStyle}" TargetType="ui:FontIcon">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDownVisible, ElementName=transferIndicator}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:FontIcon.Style>
                        </ui:FontIcon>
                        <ui:FontIcon
                            d:Foreground="#4CC2FF"
                            Foreground="{DynamicResource AccentButtonBackground}"
                            Glyph="&#xEDDC;">
                            <ui:FontIcon.Style>
                                <Style BasedOn="{StaticResource TransferIndicatorIconStyle}" TargetType="ui:FontIcon">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDownVisible, ElementName=transferIndicator}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:FontIcon.Style>
                        </ui:FontIcon>
                    </Grid>
                </Grid>
            </local:AdbMenuItem.Header>
        </local:AdbMenuItem>
    </local:AdbMenu>
</UserControl>
