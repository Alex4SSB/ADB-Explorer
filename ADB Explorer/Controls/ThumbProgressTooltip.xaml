<UserControl
    x:Class="ADB_Explorer.Controls.ThumbProgressTooltip"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ADB_Explorer.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="ThumbProgress"
    mc:Ignorable="d">
    <Grid
        Width="22"
        Height="22"
        DataContext="{Binding ElementName=ThumbProgress}"
        ToolTipService.InitialShowDelay="0"
        ToolTipService.Placement="Top"
        ToolTipService.ShowDuration="60000">
        <Grid.ToolTip>
            <ToolTip MaxWidth="800" Content="{Binding ProgressText}" />
        </Grid.ToolTip>
        <Image
            Height="16"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Source="{Binding Icon}" />
        <Rectangle
            Fill="Transparent"
            RadiusX="4"
            RadiusY="4"
            Stroke="{DynamicResource SystemFillColorCautionBrush}"
            StrokeDashArray="6.67 47.33"
            StrokeThickness="2">
            <Rectangle.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation
                                Storyboard.TargetProperty="StrokeDashOffset"
                                From="0"
                                To="-54"
                                Duration="0:0:3">
                                <DoubleAnimation.EasingFunction>
                                    <CircleEase EasingMode="EaseInOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Rectangle.Triggers>
        </Rectangle>
    </Grid>
</UserControl>
